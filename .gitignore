# Terraform state and plans (contain sensitive values incl. tokens, IPs)
*.tfstate
*.tfstate.*
*.tfstate.backup
tfplan
tfplan-*

# Variables files that may contain secrets
.env.local
*.tfvars
*.tfvars.json
!*.tfvars.example

# Terraform provider downloads / lock files (regenerated by `terraform init`)
.terraform/
.terraform.tfstate.lock.info

# Provider development checkout — separate repo, has its own remote
provider-extension/

# Editor / OS noise
.DS_Store
*.swp
.idea/
.vscode/
